# ============================================
# 美迹AI 后端环境变量配置
# ============================================

# 服务端口
PORT=9091

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=your-super-secret-key-please-change-this-to-random-string

# Supabase 数据库配置
# 从 Supabase 控制台获取：Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# 对象存储配置
# 从 Coze 控制台获取
COZE_BUCKET_ENDPOINT_URL=https://your-bucket-endpoint
COZE_BUCKET_NAME=your-bucket-name

# LLM/ASR 配置（如果使用）
# 从 Coze 控制台获取
