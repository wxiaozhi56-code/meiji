# 环境变量配置文件
# 请将此文件复制为 .env 并填写实际值

# 服务端口
PORT=9091

# JWT 配置（生产环境必须修改为随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase 数据库配置
# 从 Supabase 项目设置 > API 中获取
# 注意：代码中使用的变量名是 COZE_SUPABASE_URL 和 COZE_SUPABASE_ANON_KEY
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# 对象存储配置（可选，从 Coze 集成获取）
# COZE_BUCKET_ENDPOINT_URL=https://your-bucket.com
# COZE_BUCKET_NAME=your-bucket-name
